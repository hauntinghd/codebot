# CodeBot - Environment variables
# Copy to .env and fill in values. Never commit .env.

# --- App ---
APP_BASE_PATH=/codebot
APP_BASE_URL=https://your-domain.com
DATA_DIR=./data
DB_PATH=
PROJECTS_DIR=
UPLOADS_DIR=
STATIC_DIR=
OFFLINE_MODE=false
ALLOW_WEBSITE_PROJECTS=false

# --- Auth & session ---
JWT_SECRET=
SESSION_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
REFRESH_TOKEN_TTL_DAYS=30
CODEBOT_ADMIN_EMAILS=
RECAPTCHA_SECRET=

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=

# --- LLM: xAI / Grok (primary for Builder) ---
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning
XAI_MODEL_DEFAULT=grok-4-1-fast-reasoning
ROUTER_MODEL=grok-4-1-fast-reasoning

# --- LLM: OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_BEST=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_NATIVE_API_KEY=

# --- LLM: Anthropic ---
ANTHROPIC_API_KEY=

# --- BYOK ---
BYOK_HARD_LIMIT_DOLLARS=8.0
DEFAULT_BYOK_PROVIDER=grok
XAI_DEFAULT_MODEL=grok-4-1-fast-reasoning
BYOK_DAYS_SPREAD=14

# --- HuggingFace (optional planning) ---
HUGGINGFACEHUB_API_TOKEN=
HF_PLANNING_MODEL=
PLANNING_MODEL=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PLUS=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_CBT_500=
STRIPE_PRICE_ID_CBT_2000=
STRIPE_PRICE_ID_CBT_5000=
STRIPE_PRICE_ID_CBT_20=
STRIPE_PRICE_ID_CBT_60=
STRIPE_ALLOW_LIVE=false
STRIPE_ENABLE_TAX=false
BASE_PLAN_CBT=25000

# --- CORS ---
ALLOWED_ORIGINS=
CODEBOT_ALLOWED_ORIGINS=

# --- Limits ---
MAX_UPLOAD_BYTES=26214400
MAX_FILE_READ_BYTES=204800
MAX_CHAT_MESSAGES_CONTEXT=20
MAX_CONTEXT_TOKENS=20000

# --- Node service (billing/credits proxy) ---
NODE_SERVICE_BASE=http://127.0.0.1:4001

# --- Deploy ---
NETLIFY_API_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
CUSTOM_DOMAIN_BASE=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_CODEBOT_API_BASE=/codebot/api
ORCH_URL=

# --- Dev ---
DEV_MODE=false
