# Copy this file to `.env.e2e` and fill values (DO NOT commit real secrets to git)
# Example:
# E2E_OAUTH_EMAIL=your-test-email@example.com
# E2E_OAUTH_PASSWORD=your-test-password
# BASE_URL can override the Playwright baseURL (default: http://localhost:4173/codebot)
# BASE_URL=http://localhost:4173/codebot

# E2E_OAUTH_EMAIL=
# E2E_OAUTH_PASSWORD=
# BASE_URL=
