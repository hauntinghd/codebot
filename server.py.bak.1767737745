def stripe_mode_from_key(secret_key: str) -> str:
    if secret_key.startswith("sk_test_"):
        return "test"
    if secret_key.startswith("sk_live_"):
        return "live"
    return "unknown"


STRIPE_MODE = stripe_mode_from_key(STRIPE_SECRET_KEY) if STRIPE_SECRET_KEY else "unknown"
TEST_MODE = STRIPE_MODE == "test"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

app = FastAPI(title="AI Coder Bot Gatekeeper", version="0.5.0")

# Global concurrency limiter for LLM calls (single-process MVP)
_GLOBAL_LLM_SEM = asyncio.Semaphore(MAX_CONCURRENT)
_USER_SEMS: Dict[str, asyncio.Semaphore] = {}
_USER_SEMS_LOCK = asyncio.Lock()


async def _user_sem(user_key: str, per_user: int) -> asyncio.Semaphore:
    async with _USER_SEMS_LOCK:
        sem = _USER_SEMS.get(user_key)
        if sem is None:
            sem = asyncio.Semaphore(per_user)
            _USER_SEMS[user_key] = sem
        return sem


# -----------------------------------------------------------------------------
# SQLite storage
# -----------------------------------------------------------------------------

def _db() -> sqlite3.Connection:
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    conn = sqlite3.connect(DB_PATH, check_same_thread=False)
    conn.row_factory = sqlite3.Row
    return conn


def _column_exists(conn: sqlite3.Connection, table: str, col: str) -> bool:
    rows = conn.execute(f"PRAGMA table_info({table});").fetchall()
    for r in rows:
        if (r["name"] or "").lower() == col.lower():
            return True
    return False


def _init_db() -> None:
    conn = _db()
    try:
        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS customers (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_key TEXT UNIQUE NOT NULL,
                stripe_mode TEXT NOT NULL DEFAULT 'live',
                email TEXT,
                stripe_customer_id TEXT,
                subscription_status TEXT,
                price_id TEXT,
                current_period_end INTEGER,
                updated_at INTEGER NOT NULL
            );
            """
        )
        if not _column_exists(conn, "customers", "stripe_mode"):
            conn.execute(
                "ALTER TABLE customers ADD COLUMN stripe_mode TEXT NOT NULL DEFAULT 'live';"
            )

        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS usage_monthly (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_key TEXT NOT NULL,
                stripe_mode TEXT NOT NULL,
                yyyymm TEXT NOT NULL,
                bucket TEXT NOT NULL, -- 'standard' | 'boost'
                input_tokens INTEGER NOT NULL DEFAULT 0,
                output_tokens INTEGER NOT NULL DEFAULT 0,
                requests INTEGER NOT NULL DEFAULT 0,
                updated_at INTEGER NOT NULL,
                UNIQUE(user_key, stripe_mode, yyyymm, bucket)
            );
            """
        )

        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS projects (
                project_id TEXT PRIMARY KEY,
                user_key TEXT NOT NULL,
                name TEXT NOT NULL,
                created_at INTEGER NOT NULL,
                updated_at INTEGER NOT NULL
            );
            """
        )

        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS project_files (
                file_id TEXT PRIMARY KEY,
                project_id TEXT NOT NULL,
                user_key TEXT NOT NULL,
                kind TEXT NOT NULL, -- 'code'|'image'|'video'|'other'
                path TEXT NOT NULL,
                filename TEXT NOT NULL,
                ext TEXT,
                size_bytes INTEGER NOT NULL,
                sha256 TEXT NOT NULL,
                stored_path TEXT, -- for binary files
                text_content TEXT, -- for code/text
                created_at INTEGER NOT NULL
            );
            """
        )

        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS project_chunks (
                chunk_id TEXT PRIMARY KEY,
                project_id TEXT NOT NULL,
                user_key TEXT NOT NULL,
                file_id TEXT NOT NULL,
                file_path TEXT NOT NULL,
                start_line INTEGER NOT NULL,
                end_line INTEGER NOT NULL,
                content TEXT NOT NULL
            );
            """
        )

        conn.commit()
    finally:
        conn.close()


@app.on_event("startup")
def startup() -> None:
    _init_db()
    UPLOAD_ROOT.mkdir(parents=True, exist_ok=True)


# -----------------------------------------------------------------------------
# Customers helpers
# -----------------------------------------------------------------------------

def upsert_customer(
    *,
    user_key: str,
    stripe_mode: str,
    email: Optional[str],
    stripe_customer_id: Optional[str],
    subscription_status: Optional[str],
    price_id: Optional[str],
    current_period_end: Optional[int],
) -> None:
    now = int(time.time())
    conn = _db()
    try:
        conn.execute(
            """
            INSERT INTO customers (user_key, stripe_mode, email, stripe_customer_id, subscription_status, price_id, current_period_end, updated_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            ON CONFLICT(user_key) DO UPDATE SET
                stripe_mode=excluded.stripe_mode,
                email=excluded.email,
                stripe_customer_id=excluded.stripe_customer_id,
                subscription_status=excluded.subscription_status,
                price_id=excluded.price_id,
                current_period_end=excluded.current_period_end,
                updated_at=excluded.updated_at;
            """,
            (
                user_key,
                stripe_mode,
                email,
                stripe_customer_id,
                subscription_status,
                price_id,
                current_period_end,
                now,
            ),
        )
        conn.commit()
    finally:
        conn.close()


def get_customer_by_user_key(user_key: str) -> Optional[Dict[str, Any]]:
    conn = _db()
    try:
        row = conn.execute(
            "SELECT * FROM customers WHERE user_key = ? LIMIT 1;", (user_key,)
        ).fetchone()
        return dict(row) if row else None
    finally:
        conn.close()


def get_customer_by_stripe_customer_id(cus_id: str) -> Optional[Dict[str, Any]]:
    conn = _db()
    try:
        row = conn.execute(
            "SELECT * FROM customers WHERE stripe_customer_id = ? LIMIT 1;", (cus_id,)
        ).fetchone()
        return dict(row) if row else None
    finally:
        conn.close()


# -----------------------------------------------------------------------------
# Auth (minimal)
# -----------------------------------------------------------------------------

def require_user_key(x_user_key: Optional[str] = Header(default=None)) -> str:
    if not x_user_key or len(x_user_key) < 8:
        raise HTTPException(status_code=401, detail="Missing/invalid X-User-Key header.")
    return x_user_key


def _admin_bypass_ok(request: Optional[Request]) -> bool:
    if request is None:
        return False
    if not ADMIN_BYPASS_TOKEN:
        return False
    got = (request.headers.get("x-admin-bypass") or "").strip()
    return bool(got) and got == ADMIN_BYPASS_TOKEN


def _is_active(rec: Optional[Dict[str, Any]]) -> bool:
    if not rec:
        return False
    status = (rec.get("subscription_status") or "").lower()
    return status in ("active", "trialing")


def require_active_subscription(user_key: str = Depends(require_user_key)) -> Dict[str, Any]:
    rec = get_customer_by_user_key(user_key)
    if not rec or not _is_active(rec):
        status = ((rec or {}).get("subscription_status") or "none").lower()
        raise HTTPException(status_code=402, detail=f"Subscription required (status={status}).")
    return rec


# -----------------------------------------------------------------------------
# Plan entitlements
# -----------------------------------------------------------------------------

@dataclass(frozen=True)
class PlanLimits:
    plan: str
    standard_input_tokens: int
    standard_output_tokens: int
    boost_input_tokens: int
    boost_output_tokens: int
    per_user_concurrency: int


PLUS_LIMITS = PlanLimits(
    plan="plus",
    standard_input_tokens=80_000_000,
    standard_output_tokens=4_000_000,
    boost_input_tokens=1_000_000,
    boost_output_tokens=250_000,
    per_user_concurrency=2,
)

PRO_LIMITS = PlanLimits(
    plan="pro",
    standard_input_tokens=300_000_000,
    standard_output_tokens=20_000_000,
    boost_input_tokens=5_000_000,
    boost_output_tokens=1_000_000,
    per_user_concurrency=6,
)


def _plan_from_customer(rec: Optional[Dict[str, Any]]) -> str:
    if not rec:
        return "none"
    price_id = (rec.get("price_id") or "").strip()
    if STRIPE_PRICE_PRO and price_id == STRIPE_PRICE_PRO:
        return "pro"
    if STRIPE_PRICE_PLUS and price_id == STRIPE_PRICE_PLUS:
        return "plus"
    status = (rec.get("subscription_status") or "").lower()
    if status in ("active", "trialing"):
        return "plus"
    return "none"


def _limits_for(user_key: str, request: Optional[Request]) -> PlanLimits:
    if _admin_bypass_ok(request):
        return PlanLimits(
            plan="admin",
            standard_input_tokens=10**18,
            standard_output_tokens=10**18,
            boost_input_tokens=10**18,
            boost_output_tokens=10**18,
            per_user_concurrency=10,
        )
    rec = get_customer_by_user_key(user_key)
    plan = _plan_from_customer(rec)
    if plan == "pro":
        return PRO_LIMITS
    if plan == "plus":
        return PLUS_LIMITS
    return PlanLimits(
        plan="none",
        standard_input_tokens=0,
        standard_output_tokens=0,
        boost_input_tokens=0,
        boost_output_tokens=0,
        per_user_concurrency=1,
    )


def _yyyymm_now() -> str:
    return dt.datetime.utcnow().strftime("%Y%m")


def _usage_get(user_key: str, stripe_mode: str, yyyymm: str, bucket: str) -> Dict[str, int]:
    conn = _db()
    try:
        row = conn.execute(
            "SELECT input_tokens, output_tokens, requests FROM usage_monthly WHERE user_key=? AND stripe_mode=? AND yyyymm=? AND bucket=? LIMIT 1;",
            (user_key, stripe_mode, yyyymm, bucket),
        ).fetchone()
        if not row:
            return {"input_tokens": 0, "output_tokens": 0, "requests": 0}
        return {
            "input_tokens": int(row["input_tokens"]),
            "output_tokens": int(row["output_tokens"]),
            "requests": int(row["requests"]),
        }
    finally:
        conn.close()


def _usage_add(user_key: str, stripe_mode: str, yyyymm: str, bucket: str, input_tokens: int, output_tokens: int) -> None:
    now = int(time.time())
    conn = _db()
    try:
        conn.execute(
            """
            INSERT INTO usage_monthly (user_key, stripe_mode, yyyymm, bucket, input_tokens, output_tokens, requests, updated_at)
            VALUES (?, ?, ?, ?, ?, ?, 1, ?)
            ON CONFLICT(user_key, stripe_mode, yyyymm, bucket) DO UPDATE SET
                input_tokens = input_tokens + excluded.input_tokens,
                output_tokens = output_tokens + excluded.output_tokens,
                requests = requests + 1,
                updated_at = excluded.updated_at;
            """,
            (user_key, stripe_mode, yyyymm, bucket, int(input_tokens), int(output_tokens), now),
        )
        conn.commit()
    finally:
        conn.close()


def _ensure_quota(user_key: str, request: Optional[Request], bucket: str) -> Tuple[PlanLimits, Dict[str, int]]:
    lim = _limits_for(user_key, request)
    if lim.plan in ("none",):
        raise HTTPException(status_code=402, detail="Subscription required.")
    yyyymm = _yyyymm_now()
    used = _usage_get(user_key, STRIPE_MODE, yyyymm, bucket)

    if bucket == "standard":
        if used["input_tokens"] >= lim.standard_input_tokens or used["output_tokens"] >= lim.standard_output_tokens:
            raise HTTPException(status_code=429, detail="quota_exceeded (standard)")
    elif bucket == "boost":
        if used["input_tokens"] >= lim.boost_input_tokens or used["output_tokens"] >= lim.boost_output_tokens:
            raise HTTPException(status_code=429, detail="quota_exceeded (boost)")
    else:
        raise HTTPException(status_code=400, detail="Invalid bucket.")
    return lim, used


# -----------------------------------------------------------------------------
# Enforcement middleware
# -----------------------------------------------------------------------------

_PUBLIC_API_PATHS = {
    "/api/health",
    "/api/checkout",
    "/api/me",
    "/api/portal",
}

@app.middleware("http")
async def enforce_subscription_middleware(request: Request, call_next):
    path = request.url.path or "/"

    if not ENFORCEMENT_ENABLED:
        return await call_next(request)

    # Allow basic pages + health + Stripe webhook always.
    if path == "/health" or path.startswith("/chatbot") or path == "/" or path.startswith("/stripe/"):
        return await call_next(request)

    if path.startswith("/api/") and path not in _PUBLIC_API_PATHS:
        if _admin_bypass_ok(request):
            return await call_next(request)

        user_key = request.headers.get("x-user-key")
        if not user_key or len(user_key) < 8:
            return JSONResponse(status_code=401, content={"ok": False, "error": "missing_user_key"})

        rec = get_customer_by_user_key(user_key)
        if not _is_active(rec):
            status = ((rec or {}).get("subscription_status") or "none").lower()
            return JSONResponse(
                status_code=402,
                content={"ok": False, "error": "payment_required", "subscription_status": status},
            )

    return await call_next(request)


