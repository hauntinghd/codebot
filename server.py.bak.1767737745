@app.get("/", response_class=HTMLResponse)
async def front_door():
    # This page generates/stores a key locally (pre-alpha UX) and shows status.
    return f"""
<!doctype html>
<html>
  <head>
    <meta charset="utf-8"/>
    <title>{BRAND_NAME}</title>
  </head>
  <body style="font-family: Arial, sans-serif; margin: 28px; max-width: 980px;">
    <h1>{BRAND_NAME}</h1>
    <p>API is up.</p>
    <p><b>Stripe mode:</b> <code>{STRIPE_MODE}</code></p>

    <hr/>

    <h2>Your User Key (X-User-Key)</h2>
    <p style="margin-top:6px;">
      This is your pre-alpha login token. Keep it private.
    </p>

    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <code id="uk" style="font-size:14px; padding:8px 10px; background:#f4f4f4; border:1px solid #ddd; border-radius:6px;"></code>
      <button id="copy" style="padding:8px 10px;">Copy</button>
      <button id="regen" style="padding:8px 10px;">Regenerate</button>
    </div>

    <p id="status" style="margin-top:12px;"></p>

    <details style="margin-top:10px;">
      <summary>cURL examples</summary>
      <pre id="curl" style="white-space:pre-wrap; background:#111; color:#eee; padding:12px; border-radius:8px;"></pre>
    </details>

    <p style="margin-top:16px;"><a href="/chatbot">Go to /chatbot</a></p>

    <script>
      const LS_KEY = "aicoderbot_user_key";

      function genKey() {{
        const b = new Uint8Array(16);
        crypto.getRandomValues(b);
        const hex = Array.from(b).map(x => x.toString(16).padStart(2,"0")).join("");
        return "uk_" + hex;
      }}

      function setKey(k) {{
        localStorage.setItem(LS_KEY, k);
        document.getElementById("uk").textContent = k;
        document.getElementById("curl").textContent =
`export USER_KEY='${{k}}'
curl -sS https://chatbot.nyptidindustries.com/api/me -H "X-User-Key: $USER_KEY"
curl -sS https://chatbot.nyptidindustries.com/api/limits -H "X-User-Key: $USER_KEY"
curl -sS https://chatbot.nyptidindustries.com/api/projects -H "X-User-Key: $USER_KEY"`;
      }}

      let uk = localStorage.getItem(LS_KEY);
      if (!uk || uk.length < 12) {{
        uk = genKey();
        setKey(uk);
      }} else {{
        setKey(uk);
      }}

      document.getElementById("copy").onclick = async () => {{
        try {{
          await navigator.clipboard.writeText(uk);
          alert("Copied X-User-Key to clipboard.");
        }} catch (e) {{
          alert("Copy failed. Select and copy manually.");
        }}
      }};

      document.getElementById("regen").onclick = () => {{
        if (!confirm("Regenerate key? This creates a NEW identity.")) return;
        uk = genKey();
        setKey(uk);
        refreshStatus();
      }};

      async function refreshStatus() {{
        const el = document.getElementById("status");
        el.textContent = "Checking subscription status...";
        try {{
          const r = await fetch("/api/me", {{ headers: {{ "X-User-Key": uk }} }});
          const j = await r.json();
          const plan = j.plan || "none";
          el.innerHTML = `<b>Status:</b> <code>${{j.subscription_status}}</code> &nbsp; <b>Plan:</b> <code>${{plan}}</code>`;
        }} catch (e) {{
          el.textContent = "Could not fetch /api/me.";
        }}
      }}
      refreshStatus();
    </script>
  </body>
</html>
"""


