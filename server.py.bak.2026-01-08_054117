    function pruneTree(node, query, prefix = '') {{
      if (!query) return node;
      const q = query.toLowerCase();
      if (node.type === 'file') {{
        const full = (prefix ? `${{prefix}}/${{node.name}}` : node.name);
        if (full.toLowerCase().includes(q)) return node;
        return null;
      }}
      if (node.type === 'dir') {{
        const full = (prefix ? `${{prefix}}/${{node.name}}` : node.name);
        const kids = [];
        for (const ch of (node.children || [])) {{
          const keep = pruneTree(ch, query, full);
          if (keep) kids.push(keep);
        }}
        const selfMatch = full.toLowerCase().includes(q);
        if (kids.length || selfMatch || node.name === "root") {{
          return Object.assign({{}}, node, {{ children: kids }});
        }}
        return null;
      }}
      return node;
    }}
    function renderTree(node, container) {{
      if (!node) {{
        container.innerHTML = "No files found.";
        return;
      }}
      function renderNode(n, parent, pref) {{
        if (n.type === 'dir') {{
          const details = document.createElement("details");
          details.open = (n.name === "root");
          const summary = document.createElement("summary");
          summary.innerHTML = iconSvg("dir") + `<span class="name">${{escapeHtml(n.name)}}</span>`;
          details.appendChild(summary);
          const nextPref = (n.name === "root") ? "" : (pref ? `${{pref}}/${{n.name}}` : n.name);
          for (const ch of (n.children || [])) {{
            renderNode(ch, details, nextPref);
          }}
          parent.appendChild(details);
        }} else {{
          const fullPath = (pref ? `${{pref}}/${{n.name}}` : n.name);
          const div = document.createElement("div");
          div.className = "item";
          div.innerHTML = iconSvg(fileKind(fullPath)) + `<span class="name">${{escapeHtml(n.name)}}</span>`;
          div.addEventListener("click", () => openFile(fullPath));
          parent.appendChild(div);
        }}
      }}
      container.innerHTML = "";
      renderNode(node, container, '');
    }}
    function iconSvg(kind) {{
      const c = {{
        dir: "M3 6.5a2 2 0 0 1 2-2h2.3c.5 0 1 .2 1.3.6l.7.9H15a2 2 0 0 1 2 2v5.6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6.5z",
        code: "M6 5l-3 3 3 3M10 5l3 3-3 3M8 4l-1 8",
        file: "M6 3h5l3 3v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z",
        image: "M4 5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5zm3 8 2-2 3 3 2-2 2 2",
      }};
      const path = c[kind] || c.file;
      return `<svg class="icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="${{path}}" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>`;
    }}
    function fileKind(path) {{
      const meta = fileMetaByPath[path];
      if (!meta) return "file";
      if (meta.kind === "image") return "image";
      if (meta.kind === "code") return "code";
      return "file";
    }}
