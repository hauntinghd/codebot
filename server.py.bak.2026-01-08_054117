class ProjectChatReq(BaseModel):
    message: str
    bucket: str = "standard"
    allow_internet: bool = False
def _search_chunks(project_id: str, user_key: str, query: str, limit: int = 8) -> List[Dict[str, Any]]:
    terms = [t.lower() for t in re.findall(r"[a-zA-Z_][a-zA-Z0-9_]+", query)[:20]]
    conn = _db()
    try:
        rows = conn.execute(
            "SELECT chunk_id, file_path, start_line, end_line, content FROM project_chunks WHERE project_id=? AND user_key=?;",
            (project_id, user_key),
        ).fetchall()
    finally:
        conn.close()
    scored: List[Tuple[int, Dict[str, Any]]] = []
    for r in rows:
        content = (r["content"] or "").lower()
        score = sum(1 for t in terms if t in content)
        if score > 0:
            scored.append((score, dict(r)))
    scored.sort(key=lambda x: x[0], reverse=True)
    return [d for _, d in scored[:limit]]
async def _openai_responses(model: str, messages: List[Dict[str, Any]]) -> Tuple[str, int, int]:
    if not OPENAI_API_KEY:
        raise HTTPException(status_code=500, detail="OPENAI_API_KEY not configured")
    headers = {{"Authorization": f"Bearer {{OPENAI_API_KEY}}", "Content-Type": "application/json"}}
    body = {{"model": model, "messages": messages}}
    async with httpx.AsyncClient(timeout=60.0) as client:
        r = await client.post("https://api.openai.com/v1/chat/completions", headers=headers, json=body)
    if r.status_code != 200:
        raise HTTPException(status_code=500, detail=f"OpenAI error: {{r.text}}")
    data = r.json()
    reply = data['choices'][0]['message']['content'].strip()
    usage = data['usage']
    return reply, usage['prompt_tokens'], usage['completion_tokens']
@app.post("/api/projects/{project_id}/chat")
async def project_chat(
    project_id: str,
    payload: ProjectChatReq,
    request: Request,
    user_key: str = Depends(require_user_key),
):
    if not _project_owned(user_key, project_id):
        raise HTTPException(status_code=404, detail="Project not found")
    msg = payload.message.strip()
    if not msg:
        raise HTTPException(status_code=400, detail="message required")
    bucket = payload.bucket.lower()
    if bucket not in ("standard", "boost"):
        raise HTTPException(status_code=400, detail="invalid bucket")
    lim, _ = _ensure_quota(user_key, request, bucket)
    model = OPENAI_MODEL_BOOST if bucket == "boost" else OPENAI_MODEL_TEXT
    chunks = _search_chunks(project_id, user_key, msg)
    context = '\n\n'.join([f"### {{c['file_path']}}:{{c['start_line']}}-{{c['end_line']}}\n{{c['content']}}" for c in chunks])
    citations = [f"{{c['file_path']}}:{{c['start_line']}}-{{c['end_line']}}" for c in chunks]
    system = "You are a code assistant using only provided context. No guessing. If needed, ask for more files. For fixes, output true unified diff with ---/+++/@@."
    user_text = f"Request: {{msg}}\n\nallow_internet: {{payload.allow_internet}}\n\nContext: {{context or '(none)'}}"
    messages = [{{"role": "system", "content": system}}, {{"role": "user", "content": user_text}}]
    async with _GLOBAL_LLM_SEM:
        async with await _user_sem(user_key, lim.per_user_concurrency):
            reply_text, in_tok, out_tok = await _openai_responses(model, messages)
    # Verification check
    verify_system = "Verify response for hallucinations, inaccuracies vs context. Correct if needed, else repeat original."
    verify_user = f"Response: {{reply_text}}\n\nContext: {{context}}\nRequest: {{msg}}"
    verify_messages = [{{"role": "system", "content": verify_system}}, {{"role": "user", "content": verify_user}}]
    async with _GLOBAL_LLM_SEM:
        async with await _user_sem(user_key, lim.per_user_concurrency):
            verified_text, in_tok2, out_tok2 = await _openai_responses(model, verify_messages)
    in_tok += in_tok2
    out_tok += out_tok2
    _usage_add(user_key, STRIPE_MODE, _yyyymm_now(), bucket, in_tok, out_tok)
    return {{"ok": True, "reply": verified_text, "citations": citations}}
