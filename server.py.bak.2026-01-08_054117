class CheckoutRequest(BaseModel):
    plan: str
    email: Optional[str] = None
@app.post("/api/checkout")
async def create_checkout(payload: CheckoutRequest, user_key: str = Depends(require_user_key)):
    if not STRIPE_SECRET_KEY:
        raise HTTPException(status_code=500, detail="Stripe not configured (missing STRIPE_SECRET_KEY).")
    plan = payload.plan.strip().lower()
    if plan not in ("plus", "pro"):
        raise HTTPException(status_code=400, detail="plan must be 'plus' or 'pro'.")
    if plan == "pro" and not STRIPE_PRICE_PRO:
        raise HTTPException(status_code=400, detail="Pro plan not enabled.")
    if plan == "plus" and not STRIPE_PRICE_PLUS:
        raise HTTPException(status_code=500, detail="Missing STRIPE_PRICE_PLUS.")
    price_id = STRIPE_PRICE_PLUS if plan == "plus" else STRIPE_PRICE_PRO
    existing = get_customer_by_user_key(user_key)
    existing_mode = (existing or {}).get("stripe_mode") or "live"
    stripe_customer_id = (existing or {}).get("stripe_customer_id")
    if existing and stripe_customer_id and existing_mode == STRIPE_MODE:
        customer_id = stripe_customer_id
        if payload.email:
            try:
                stripe.Customer.modify(customer_id, email=payload.email)
            except Exception:
                pass
    else:
        customer = stripe.Customer.create(email=payload.email, metadata={{"user_key": user_key}})
        customer_id = customer["id"]
        upsert_customer(
            user_key=user_key,
            stripe_mode=STRIPE_MODE,
            email=payload.email,
            stripe_customer_id=customer_id,
            subscription_status="incomplete",
            price_id=price_id,
            current_period_end=None,
        )
    success_url = f"{{APP_BASE_URL}}/?checkout=success&session_id={{CHECKOUT_SESSION_ID}}"
    cancel_url = f"{{APP_BASE_URL}}/?checkout=cancel"
    session = stripe.checkout.Session.create(
        mode="subscription",
        customer=customer_id,
        line_items=[{{"price": price_id, "quantity": 1}}],
        success_url=success_url,
        cancel_url=cancel_url,
        allow_promotion_codes=True,
        subscription_data={{"metadata": {{"user_key": user_key, "plan": plan}}}},
        metadata={{"user_key": user_key, "plan": plan}},
    )
    return {
        "ok": True,
        "checkout_url": session["url"],
        "session_id": session["id"],
        "stripe_mode": STRIPE_MODE,
        "test_mode": TEST_MODE,
    }
def _extract_subscription_fields(sub: Dict[str, Any]) -> Dict[str, Any]:
    status = sub.get("status")
    current_period_end = sub.get("current_period_end")
    items = sub.get("items", {}).get("data", [])
    price_id = None
    if items:
        price = items[0].get("price") or {}
        price_id = price.get("id")
    return {
        "subscription_status": status,
        "current_period_end": int(current_period_end) if current_period_end else None,
        "price_id": price_id,
    }
@app.post("/api/checkout/confirm")
async def confirm_checkout(session_id: str, user_key: str = Depends(require_user_key)):
    if not STRIPE_SECRET_KEY:
        raise HTTPException(status_code=500, detail="Stripe not configured (missing STRIPE_SECRET_KEY).")
    try:
        sess = stripe.checkout.Session.retrieve(session_id, expand=["subscription"])
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"Invalid session_id: {{e}}")
    meta = sess.get("metadata") or {}
    sess_user_key = (meta.get("user_key") or "").strip()
    if sess_user_key and sess_user_key != user_key:
        raise HTTPException(status_code=403, detail="Session does not belong to this user_key.")
    customer_id = sess.get("customer")
    sub = sess.get("subscription")
    if isinstance(sub, str):
        try:
            sub = stripe.Subscription.retrieve(sub)
        except Exception:
            sub = None
    if not customer_id or not isinstance(sub, dict):
        return {{ "ok": False, "detail": "Checkout not completed yet." }}
    fields = _extract_subscription_fields(sub)
    upsert_customer(
        user_key=user_key,
        stripe_mode=STRIPE_MODE,
        email=None,
        stripe_customer_id=customer_id,
        subscription_status=fields["subscription_status"],
        price_id=fields["price_id"],
        current_period_end=fields["current_period_end"],
    )
    return {{ "ok": True, **fields }}
class PortalRequest(BaseModel):
    return_url: Optional[str] = None
@app.post("/api/portal")
async def create_billing_portal(payload: PortalRequest, user_key: str = Depends(require_user_key)):
    if not STRIPE_SECRET_KEY:
        raise HTTPException(status_code=500, detail="Stripe not configured (missing STRIPE_SECRET_KEY).")
    rec = get_customer_by_user_key(user_key)
    if not rec or not rec.get("stripe_customer_id"):
        raise HTTPException(status_code=404, detail="No Stripe customer found.")
    if (rec.get("stripe_mode") or "live") != STRIPE_MODE:
        raise HTTPException(
            status_code=409,
            detail="Customer exists in different Stripe mode; start a new checkout in current mode.",
        )
    portal = stripe.billing_portal.Session.create(
        customer=rec["stripe_customer_id"],
        return_url=payload.return_url or f"{{APP_BASE_URL}}/",
    )
    return {{ "ok": True, "url": portal["url"] }}
