      <div style="padding:14px; border:1px solid #e5e7eb; border-radius:12px;">
        <h2 style="margin:0 0 10px 0; font-size:18px;">Usage & Limits</h2>
        <div id="limitsBox" style="font-size:14px; color:#111;">
          <div style="color:#6b7280;">Loading limits…</div>
        </div>
        <div id="limitsErr" style="margin-top:10px; color:#b91c1c;"></div>
      </div>
    </div>
    <p id="checkoutMsg" style="margin-top:12px;"></p>
    {_shared_js()}
    <script>
      let uk = window.__aicoderbot.getKey();
      window.__aicoderbot.setKeyUI(uk);
      document.getElementById("copy").onclick = async () => {{
        try {{
          await navigator.clipboard.writeText(uk);
          alert("Copied X-User-Key.");
        }} catch (e) {{
          alert("Copy failed. Select and copy manually.");
        }}
      }};
      document.getElementById("regen").onclick = () => {{
        if (!confirm("Regenerate key? This creates a NEW identity.")) return;
        uk = (function() {{
          const b = new Uint8Array(16);
          crypto.getRandomValues(b);
          const hex = Array.from(b).map(x => x.toString(16).padStart(2,"0")).join("");
          return "uk_" + hex;
        }})();
        localStorage.setItem("aicoderbot_user_key", uk);
        window.__aicoderbot.setKeyUI(uk);
        window.__aicoderbot.refreshStatus();
        loadProjects();
        loadLimits();
      }};
      document.getElementById("buyPlus").onclick = () => window.__aicoderbot.startCheckout("plus");
      document.getElementById("buyPro").onclick = () => window.__aicoderbot.startCheckout("pro");
      document.getElementById("portal").onclick = () => window.__aicoderbot.openPortal();
      function esc(s) {{
        return (s||"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;");
      }}
      async function loadProjects() {{
        const box = document.getElementById("projectsBox");
        const err = document.getElementById("projectsErr");
        err.textContent = "";
        box.innerHTML = '<div style="color:#6b7280;">Loading projects…</div>';
        try {{
          const j = await window.__aicoderbot.api("/api/projects");
          const ps = j.projects || [];
          if (!ps.length) {{
            box.innerHTML = '<div style="color:#6b7280;">No projects yet. Create one.</div>';
            return;
          }}
          let html = '<div style="display:flex; flex-direction:column; gap:8px;">';
          for (const p of ps) {{
            html += `
              <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px; border:1px solid #e5e7eb; border-radius:10px;">
                <div>
                  <div style="font-weight:600;">${{esc(p.name)}} <code style="font-weight:400; color:#6b7280;">${{p.project_id}}</code></div>
                  <div style="color:#6b7280; font-size:12px;">Updated: ${{new Date((p.updated_at||0)*1000).toLocaleString()}}</div>
                </div>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                  <a href="/codebot?project_id=${{encodeURIComponent(p.project_id)}}" style="padding:8px 10px; border:1px solid #e5e7eb; border-radius:10px; text-decoration:none; color:#111;">Open</a>
                </div>
              </div>`;
          }}
          html += "</div>";
          box.innerHTML = html;
        }} catch (e) {{
          err.textContent = "Projects unavailable (likely no active subscription yet).";
          box.innerHTML = '<div style="color:#6b7280;">—</div>';
        }}
      }}
      async function loadLimits() {{
        const box = document.getElementById("limitsBox");
        const err = document.getElementById("limitsErr");
        err.textContent = "";
        box.innerHTML = '<div style="color:#6b7280;">Loading limits…</div>';
        try {{
          const j = await window.__aicoderbot.api("/api/limits");
          const u = j.used || {{ standard:{{}}, boost:{{}} }};
          const l = j.limits || {{ standard:{{}}, boost:{{}} }};
          box.innerHTML = `
            <div><b>Month:</b> <code>${{j.yyyymm}}</code></div>
            <div style="margin-top:8px; padding:10px; border:1px solid #e5e7eb; border-radius:10px;">
              <div style="font-weight:600;">Standard</div>
              <div>Input tokens: <code>${{u.standard.input_tokens||0}}</code> / <code>${{l.standard.input_tokens||0}}</code></div>
              <div>Output tokens: <code>${{u.standard.output_tokens||0}}</code> / <code>${{l.standard.output_tokens||0}}</code></div>
              <div>Requests: <code>${{u.standard.requests||0}}</code></div>
            </div>
            <div style="margin-top:10px; padding:10px; border:1px solid #e5e7eb; border-radius:10px;">
              <div style="font-weight:600;">Boost</div>
              <div>Input tokens: <code>${{u.boost.input_tokens||0}}</code> / <code>${{l.boost.input_tokens||0}}</code></div>
              <div>Output tokens: <code>${{u.boost.output_tokens||0}}</code> / <code>${{l.boost.output_tokens||0}}</code></div>
              <div>Requests: <code>${{u.boost.requests||0}}</code></div>
            </div>
          `;
        }} catch (e) {{
          err.textContent = "Limits unavailable (likely no active subscription yet).";
          box.innerHTML = '<div style="color:#6b7280;">—</div>';
        }}
      }}
      document.getElementById("createProject").onclick = async () => {{
        const name = (document.getElementById("newProjectName").value || "").trim();
        const err = document.getElementById("projectsErr");
        err.textContent = "";
        if (!name) {{
          err.textContent = "Project name required.";
          return;
        }}
        try {{
          const j = await window.__aicoderbot.api("/api/projects", {{ method:"POST", body:{{ name }} }});
          window.__aicoderbot.setLastProject(j.project_id);
          document.getElementById("newProjectName").value = "";
          await loadProjects();
        }} catch (e) {{
          err.textContent = "Create project failed: " + JSON.stringify(e.data || e);
        }}
      }};
      (async () => {{
        await window.__aicoderbot.refreshStatus();
        await window.__aicoderbot.confirmIfNeeded();
        await loadProjects();
        await loadLimits();
      }})();
    </script>
  </body>
</html>
"""
