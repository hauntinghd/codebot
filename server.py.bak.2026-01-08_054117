    norm = _normalize_rel_path(path)
    f = _get_file_by_path(user_key, project_id, norm)
    if not f:
        raise HTTPException(status_code=404, detail="File not found")
    kind = f.get("kind")
    ext = (f.get("ext") or Path(norm).suffix).lower()
    if kind == "code":
        text = f.get("text_content") or ""
        if ext == ".html":
            return HTMLResponse(content=text)
        if ext == ".md":
            html_body = _render_markdown_to_html(text)
            return HTMLResponse(content=f"<!doctype html><html><body>{{html_body}}</body></html>")
        return PlainTextResponse(content=text)
    if kind == "image":
        p = f.get("stored_path")
        if not p:
            raise HTTPException(status_code=404, detail="Image missing")
        b = Path(p).read_bytes()
        return Response(content=b, media_type=_guess_mime_for_image_ext(ext))
    return PlainTextResponse(content="[preview blocked]")
