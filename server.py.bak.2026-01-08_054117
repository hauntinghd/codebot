    function renderMessage(text) {{
      const s = (text ?? '').toString();
      if (!s.includes('```')) return escapeHtml(s).replaceAll('\n', '<br/>');
      const parts = s.split('```');
      let out = '';
      for (let i = 0; i < parts.length; i++) {{
        const chunk = parts[i];
        if (i % 2 === 0) {{
          out += escapeHtml(chunk).replaceAll('\n', '<br/>');
        }} else {{
          const lines = chunk.replaceAll('\r\n','\n').split('\n');
          const first = (lines[0] || '').trim();
          const code = lines.slice(1).join('\n');
          out += `<div style="margin:8px 0;border:1px solid rgba(148,163,184,.18);border-radius:12px;overflow:hidden">
            <div style="padding:6px 10px;background:rgba(15,23,42,.55);color:rgba(229,231,235,.8);font-size:12px">${{escapeHtml(first || 'code')}}</div>
            <pre style="margin:0;padding:10px;overflow:auto;background:rgba(2,6,23,.35);font-family:var(--mono);font-size:12px">${{escapeHtml(code)}}</pre>
          </div>`;
        }}
      }}
      return out;
    }}
    function extractUnifiedDiff(text) {{
      const s = (text || '').replaceAll('\r\n','\n');
      const lines = s.split('\n');
      let start = -1;
      for (let i = 0; i < lines.length; i++) {{
        if (lines[i].startsWith('--- ')) {{ start = i; break; }}
      }}
      if (start === -1) return null;
      const tail = lines.slice(start).join('\n');
      if (!tail.includes('\n+++ ') || !tail.includes('\n@@')) return null;
      return tail.trim();
    }}
