    with zipfile.ZipFile(buf, "w", compression=zipfile.ZIP_DEFLATED) as zf:
        for r in rows:
            p = r["path"]
            kind = r["kind"]
            if kind == "code":
                data = (r["text_content"] or "").encode("utf-8")
                zf.writestr(p, data)
            else:
                sp = r["stored_path"]
                if not sp:
                    continue
                sp_path = Path(sp)
                if not sp_path.exists():
                    continue
                data = sp_path.read_bytes()
                zf.writestr(p, data)
    buf.seek(0)
    return Response(content=buf.getvalue(), media_type="application/zip", headers={{"Content-Disposition": "attachment; filename=project.zip"}})
