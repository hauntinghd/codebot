def _render_markdown_to_html(md: str) -> str:
    try:
        import markdown
        return markdown.markdown(md, extensions=["fenced_code", "tables"])
    except Exception:
        escaped = _html.escape(md or "")
        return "<pre style='white-space:pre-wrap;'>" + escaped + "</pre>"
