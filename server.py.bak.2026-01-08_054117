_USER_SEMS: Dict[str, asyncio.Semaphore] = {}
_USER_SEMS_LOCK = asyncio.Lock()
async def _user_sem(user_key: str, per_user: int) -> asyncio.Semaphore:
    async with _USER_SEMS_LOCK:
        sem = _USER_SEMS.get(user_key)
        if sem is None:
            sem = asyncio.Semaphore(per_user)
            _USER_SEMS[user_key] = sem
        return sem
