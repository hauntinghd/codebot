        node = root
        for part in parts[:-1]:
            found = next((c for c in node["children"] if c["name"] == part and c["type"] == "dir"), None)
            if not found:
                found = {{"type": "dir", "name": part, "children": []}}
                node["children"].append(found)
            node = found
        node["children"].append({{"type": "file", "name": parts[-1]}})
    return {{"ok": True, "tree": root}}
