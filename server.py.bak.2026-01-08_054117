@dataclass(frozen=True)
class PlanLimits:
    plan: str
    standard_input_tokens: int
    standard_output_tokens: int
    boost_input_tokens: int
    boost_output_tokens: int
    per_user_concurrency: int
PLUS_LIMITS = PlanLimits(
    plan="plus",
    standard_input_tokens=80_000_000,
    standard_output_tokens=4_000_000,
    boost_input_tokens=1_000_000,
    boost_output_tokens=250_000,
    per_user_concurrency=2,
)
PRO_LIMITS = PlanLimits(
    plan="pro",
    standard_input_tokens=300_000_000,
    standard_output_tokens=20_000_000,
    boost_input_tokens=5_000_000,
    boost_output_tokens=1_000_000,
    per_user_concurrency=6,
)
def _plan_from_customer(rec: Optional[Dict[str, Any]]) -> str:
    if not rec:
        return "none"
    price_id = (rec.get("price_id") or "").strip()
    if STRIPE_PRICE_PRO and price_id == STRIPE_PRICE_PRO:
        return "pro"
    if STRIPE_PRICE_PLUS and price_id == STRIPE_PRICE_PLUS:
        return "plus"
    status = (rec.get("subscription_status") or "").lower()
    if status in ("active", "trialing"):
        return "plus"
    return "none"
def _limits_for(user_key: str, request: Optional[Request]) -> PlanLimits:
    if _admin_bypass_ok(request):
        return PlanLimits(
            plan="admin",
            standard_input_tokens=10**18,
            standard_output_tokens=10**18,
            boost_input_tokens=10**18,
            boost_output_tokens=10**18,
            per_user_concurrency=10,
        )
    rec = get_customer_by_user_key(user_key)
    plan = _plan_from_customer(rec)
    if plan == "pro":
        return PRO_LIMITS
    if plan == "plus":
        return PLUS_LIMITS
    return PlanLimits(
        plan="none",
        standard_input_tokens=0,
        standard_output_tokens=0,
        boost_input_tokens=0,
        boost_output_tokens=0,
        per_user_concurrency=1,
    )
def _yyyymm_now() -> str:
    return dt.datetime.utcnow().strftime("%Y%m")
def _usage_get(user_key: str, stripe_mode: str, yyyymm: str, bucket: str) -> Dict[str, int]:
    conn = _db()
    try:
        row = conn.execute(
            "SELECT input_tokens, output_tokens, requests FROM usage_monthly WHERE user_key=? AND stripe_mode=? AND yyyymm=? AND bucket=? LIMIT 1;",
            (user_key, stripe_mode, yyyymm, bucket),
        ).fetchone()
        if not row:
            return {"input_tokens": 0, "output_tokens": 0, "requests": 0}
        return {
            "input_tokens": int(row["input_tokens"]),
            "output_tokens": int(row["output_tokens"]),
            "requests": int(row["requests"]),
        }
    finally:
        conn.close()
def _usage_add(user_key: str, stripe_mode: str, yyyymm: str, bucket: str, input_tokens: int, output_tokens: int) -> None:
    now = int(time.time())
    conn = _db()
    try:
        conn.execute(
            """
            INSERT INTO usage_monthly (user_key, stripe_mode, yyyymm, bucket, input_tokens, output_tokens, requests, updated_at)
            VALUES (?, ?, ?, ?, ?, ?, 1, ?)
            ON CONFLICT(user_key, stripe_mode, yyyymm, bucket) DO UPDATE SET
                input_tokens = input_tokens + excluded.input_tokens,
                output_tokens = output_tokens + excluded.output_tokens,
                requests = requests + 1,
                updated_at = excluded.updated_at;
            """,
            (user_key, stripe_mode, yyyymm, bucket, int(input_tokens), int(output_tokens), now),
        )
        conn.commit()
    finally:
        conn.close()
def _ensure_quota(user_key: str, request: Optional[Request], bucket: str) -> Tuple[PlanLimits, Dict[str, int]]:
    lim = _limits_for(user_key, request)
    if lim.plan in ("none",):
        raise HTTPException(status_code=402, detail="Subscription required.")
    yyyymm = _yyyymm_now()
    used = _usage_get(user_key, STRIPE_MODE, yyyymm, bucket)
    if bucket == "standard":
        if used["input_tokens"] >= lim.standard_input_tokens or used["output_tokens"] >= lim.standard_output_tokens:
            raise HTTPException(status_code=429, detail="quota_exceeded (standard)")
    elif bucket == "boost":
        if used["input_tokens"] >= lim.boost_input_tokens or used["output_tokens"] >= lim.boost_output_tokens:
            raise HTTPException(status_code=429, detail="quota_exceeded (boost)")
    else:
        raise HTTPException(status_code=400, detail="Invalid bucket.")
    return lim, used
# -----------------------------------------------------------------------------
# Enforcement middleware
# -----------------------------------------------------------------------------
_PUBLIC_API_PATHS = {
    "/api/health",
    "/api/checkout",
    "/api/checkout/confirm", # allow confirm without active sub
    "/api/me",
    "/api/portal",
}
@app.middleware("http")
async def enforce_subscription_middleware(request: Request, call_next):
    path = request.url.path or "/"
    if not ENFORCEMENT_ENABLED:
        return await call_next(request)
    # Allow basic pages + health + Stripe webhook always + preview page (iframe)
    if (
        path == "/health"
        or path.startswith("/codebot")
        or path.startswith("/chatbot")
        or path == "/"
        or path.startswith("/stripe/")
        or path.startswith("/preview/")
    ):
        return await call_next(request)
    if path.startswith("/api/") and path not in _PUBLIC_API_PATHS:
        if _admin_bypass_ok(request):
            return await call_next(request)
        user_key = request.headers.get("x-user-key")
        if not user_key or len(user_key) < 8:
            return JSONResponse(status_code=401, content={{ "ok": False, "error": "missing_user_key" }})
        rec = get_customer_by_user_key(user_key)
        if not _is_active(rec):
            status = ((rec or {}).get("subscription_status") or "none").lower()
            return JSONResponse(
                status_code=402,
                content={{ "ok": False, "error": "payment_required", "subscription_status": status }},
            )
    return await call_next(request)
