@app.post("/api/projects/{project_id}/suggest_files")
async def suggest_files(
    project_id: str,
    payload: SuggestFilesReq,
    request: Request,
    user_key: str = Depends(require_user_key),
):
    if not _project_owned(user_key, project_id):
        raise HTTPException(status_code=404, detail="Project not found")
    _ensure_quota(user_key, request, "standard")
    system = (
        "You are a strict debugging intake agent.\n"
        "Rules:\n"
        "- You MUST output valid JSON only.\n"
        "- JSON schema:\n"
        ' {{"needed_files":[...], "count":N, "why":"...", "internet_required":true|false}}\n'
        "- needed_files must be exact file paths as shown in the folder tree.\n"
        f"- Max needed_files is {{MAX_UPLOAD_FILES}}.\n"
        "- If you cannot see any file paths, return empty needed_files and explain what is missing.\n"
        "- Do NOT guess file names.\n"
    )
    user_text = f"Goal:\n{{payload.request_text}}\n\nFolder tree text:\n{{payload.folder_tree_text or '(none)'}}"
    messages = [{{"role": "system", "content": system}}, {{"role": "user", "content": user_text}}]
    reply_text, in_tok, out_tok = await _openai_responses(OPENAI_MODEL_TEXT, messages)
    _usage_add(user_key, STRIPE_MODE, _yyyymm_now(), "standard", in_tok, out_tok)
    obj = _extract_first_json_object(reply_text) or {{}}
    needed = obj.get("needed_files", [])[:MAX_UPLOAD_FILES]
    why = obj.get("why", "")[:2000]
    internet_required = bool(obj.get("internet_required", False))
    return {{
        "ok": True,
        "needed_files": needed,
        "count": len(needed),
        "why": why,
        "internet_required": internet_required,
    }}
def _extract_first_json_object(text: str) -> Optional[Dict[str, Any]]:
    s = text or ""
    start = s.find("{{")
    if start < 0:
        return None
    depth = 0
    in_str = False
    esc = False
    for i in range(start, len(s)):
        ch = s[i]
        if in_str:
            if esc:
                esc = False
            elif ch == "\\":
                esc = True
            elif ch == '"':
                in_str = False
            continue
        if ch == '"':
            in_str = True
            continue
        if ch == "{{":
            depth += 1
        elif ch == "}}":
            depth -= 1
            if depth == 0:
                blob = s[start : i + 1]
                try:
                    import json
                    obj = json.loads(blob)
                    if isinstance(obj, dict):
                        return obj
                except Exception:
                    return None
    return None