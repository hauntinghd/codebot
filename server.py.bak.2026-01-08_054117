def _strip_diff_path(p: str) -> str:
    p = (p or "").strip()
    if p.startswith("a/") or p.startswith("b/"):
        p = p[2:]
    return p
def _parse_unified_diff(diff_text: str) -> List[Dict[str, Any]]:
    lines = (diff_text or "").splitlines()
    i = 0
    patches: List[Dict[str, Any]] = []
    def _expect(prefix: str) -> str:
        nonlocal i
        if i >= len(lines) or not lines[i].startswith(prefix):
            raise HTTPException(status_code=400, detail=f"Invalid diff: expected '{{prefix}}' at line {{i+1}}")
        s = lines[i][len(prefix):].strip()
        i += 1
        return s
    while i < len(lines):
        if not lines[i].startswith("--- "):
            i += 1
            continue
        old_path = _expect("--- ")
        new_path = _expect("+++ ")
        hunks: List[Dict[str, Any]] = []
        while i < len(lines) and lines[i].startswith("@@ "):
            header = lines[i]
            i += 1
            m = re.match(r"@@ -(\d+)(?:,(\d+))? \+(\d+)(?:,(\d+))? @@", header)
            if not m:
                raise HTTPException(status_code=400, detail=f"Invalid hunk header: {{header}}")
            old_start = int(m.group(1))
            old_count = int(m.group(2) or "1")
            new_start = int(m.group(3))
            new_count = int(m.group(4) or "1")
            hlines: List[str] = []
            while i < len(lines) and not lines[i].startswith("--- ") and not lines[i].startswith("@@ "):
                hlines.append(lines[i])
                i += 1
            hunks.append({{
                "old_start": old_start, "old_count": old_count,
                "new_start": new_start, "new_count": new_count,
                "lines": hlines
            }})
        patches.append({{"old_path": old_path, "new_path": new_path, "hunks": hunks}})
    if not patches:
        raise HTTPException(status_code=400, detail="No file patches found in diff.")
    return patches
def _apply_patch_to_lines(orig_lines: List[str], hunks: List[Dict[str, Any]]) -> List[str]:
    out: List[str] = []
    src_index = 0
    for h in hunks:
        old_start = int(h["old_start"])
        target = max(0, old_start - 1)
        if target < src_index:
            raise HTTPException(status_code=400, detail="Invalid diff: overlapping hunks.")
        out.extend(orig_lines[src_index:target])
        src_index = target
        for raw in h["lines"]:
            if raw.startswith("\\ No newline at end of file"):
                continue
            if not raw:
                raise HTTPException(status_code=400, detail="Invalid diff: empty hunk line without prefix.")
            prefix = raw[0]
            text = raw[1:] if len(raw) > 1 else ""
            if prefix == " ":
                if src_index >= len(orig_lines) or orig_lines[src_index] != text:
                    raise HTTPException(status_code=400, detail="Patch context mismatch.")
                out.append(text)
                src_index += 1
            elif prefix == "-":
                if src_index >= len(orig_lines) or orig_lines[src_index] != text:
                    raise HTTPException(status_code=400, detail="Patch remove mismatch.")
                src_index += 1
            elif prefix == "+":
                out.append(text)
            else:
                raise HTTPException(status_code=400, detail=f"Invalid diff line prefix: {{prefix}}")
    out.extend(orig_lines[src_index:])
    return out
@app.post("/api/projects/{project_id}/apply_diff")
async def apply_diff(project_id: str, payload: ApplyDiffReq, user_key: str = Depends(require_user_key)):
    if not _project_owned(user_key, project_id):
        raise HTTPException(status_code=404, detail="Project not found")
    diff_text = (payload.diff or "").strip()
    if not diff_text:
        raise HTTPException(status_code=400, detail="diff required")
    patches = _parse_unified_diff(diff_text)
    updated_paths: List[str] = []
    created_paths: List[str] = []
    deleted_paths: List[str] = []
    conn = _db()
    try:
        for p in patches:
            old_raw = p["old_path"]
            new_raw = p["new_path"]
            old_path = _strip_diff_path(old_raw)
            new_path = _strip_diff_path(new_raw)
            old_is_null = old_path == "/dev/null"
            new_is_null = new_path == "/dev/null"
            if new_is_null and old_is_null:
                continue
            target_path = new_path if not new_is_null else old_path
            if target_path == "/dev/null":
                continue
            norm = _normalize_rel_path(target_path)
            existing = _find_file_by_path(conn, project_id, user_key, norm)
            if new_is_null:
                if existing:
                    file_id = existing["file_id"]
                    _delete_chunks_for_file(conn, project_id, user_key, file_id)
                    conn.execute(
                        "DELETE FROM project_files WHERE project_id=? AND user_key=? AND file_id=?;",
                        (project_id, user_key, file_id),
                    )
                    deleted_paths.append(norm)
                continue
            if old_is_null and not existing:
                orig_lines: List[str] = []
            else:
                if not existing:
                    raise HTTPException(status_code=400, detail=f"Diff refers to missing file: {{norm}}")
                if existing["kind"] != "code":
                    raise HTTPException(status_code=400, detail=f"Diff can only apply to code/text files: {{norm}}")
                orig_text = existing["text_content"] or ""
                orig_lines = orig_text.splitlines()
            new_lines = _apply_patch_to_lines(orig_lines, p["hunks"])
            new_text = "\n".join(new_lines) + "\n" if new_lines else ""
            data = new_text.encode("utf-8")
            ext = Path(norm).suffix.lower()
            kind = "code"
            saved = _upsert_project_file(
                conn=conn,
                project_id=project_id,
                user_key=user_key,
                path=norm,
                filename=Path(norm).name,
                kind=kind,
                ext=ext,
                data=data,
            )
            if existing:
                updated_paths.append(norm)
            else:
                created_paths.append(norm)
        conn.commit()
    finally:
        conn.close()
    _touch_project(project_id, user_key)
    return {{
        "ok": True,
        "updated_paths": updated_paths,
        "created_paths": created_paths,
        "deleted_paths": deleted_paths,
        "counts": {{
            "updated": len(updated_paths),
            "created": len(created_paths),
            "deleted": len(deleted_paths),
        }},
    }}
