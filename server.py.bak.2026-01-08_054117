def _find_file_by_path(conn: sqlite3.Connection, project_id: str, user_key: str, path: str) -> Optional[sqlite3.Row]:
    return conn.execute(
        "SELECT * FROM project_files WHERE project_id=? AND user_key=? AND path=? LIMIT 1;",
        (project_id, user_key, path),
    ).fetchone()
def _delete_chunks_for_file(conn: sqlite3.Connection, project_id: str, user_key: str, file_id: str) -> None:
    conn.execute(
        "DELETE FROM project_chunks WHERE project_id=? AND user_key=? AND file_id=?;",
        (project_id, user_key, file_id),
    )
def _upsert_project_file(
    *,
    conn: sqlite3.Connection,
    project_id: str,
    user_key: str,
    path: str,
    filename: str,
    kind: str,
    ext: str,
    data: bytes,
) -> Dict[str, Any]:
    path = _normalize_rel_path(path)
    filename = (filename or Path(path).name).strip() or Path(path).name
    ext = (ext or Path(filename).suffix).lower()
    sha = _sha256_bytes(data)
    size_bytes = len(data)
    existing = _find_file_by_path(conn, project_id, user_key, path)
    file_id = (existing["file_id"] if existing else ("f_" + uuid.uuid4().hex))
    stored_path: Optional[str] = None
    text_content: Optional[str] = None
    if kind in ("image", "video", "other"):
        prj_dir = _project_dir(user_key, project_id)
        prj_dir.mkdir(parents=True, exist_ok=True)
        safe_name = re.sub(r"[^a-zA-Z0-9._\\-]+", "_", filename)
        out_path = (prj_dir / f"{{file_id}}_{{safe_name}}").resolve()
        out_path.write_bytes(data)
        stored_path = str(out_path)
    else:
        try:
            text_content = data.decode("utf-8")
        except UnicodeDecodeError:
            kind = "other"
            prj_dir = _project_dir(user_key, project_id)
            prj_dir.mkdir(parents=True, exist_ok=True)
            safe_name = re.sub(r"[^a-zA-Z0-9._\\-]+", "_", filename)
            out_path = (prj_dir / f"{{file_id}}_{{safe_name}}").resolve()
            out_path.write_bytes(data)
            stored_path = str(out_path)
            text_content = None
    created_at = int(existing["created_at"]) if existing else _now()
    if existing:
        conn.execute(
            """
            UPDATE project_files
            SET kind=?, filename=?, ext=?, size_bytes=?, sha256=?, stored_path=?, text_content=?
            WHERE project_id=? AND user_key=? AND file_id=?;
            """,
            (kind, filename, ext, size_bytes, sha, stored_path, text_content, project_id, user_key, file_id),
        )
        _delete_chunks_for_file(conn, project_id, user_key, file_id)
    else:
        conn.execute(
            """
            INSERT INTO project_files
            (file_id, project_id, user_key, kind, path, filename, ext, size_bytes, sha256, stored_path, text_content, created_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);
            """,
            (file_id, project_id, user_key, kind, path, filename, ext, size_bytes, sha, stored_path, text_content, created_at),
        )
    if kind == "code" and text_content:
        for (start, end, chunk) in _chunk_text(path, text_content, max_lines=250):
            chunk_id = "c_" + uuid.uuid4().hex
            conn.execute(
                """
                INSERT INTO project_chunks (chunk_id, project_id, user_key, file_id, file_path, start_line, end_line, content)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?);
                """,
                (chunk_id, project_id, user_key, file_id, path, start, end, chunk),
            )
    return {{"file_id": file_id, "filename": filename, "path": path, "kind": kind, "size_bytes": size_bytes}}
