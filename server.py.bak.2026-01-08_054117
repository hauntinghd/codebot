def _now() -> int:
    return int(time.time())
def _project_dir(user_key: str, project_id: str) -> Path:
    safe_user = re.sub(r"[^a-zA-Z0-9_\-]", "_", user_key)
    return (UPLOAD_ROOT / safe_user / project_id).resolve()
_TEXT_EXTS = {{
    ".py", ".js", ".ts", ".tsx", ".json", ".yaml", ".yml", ".md", ".txt", ".html", ".css",
    ".go", ".rs", ".java", ".kt", ".cs", ".c", ".cc", ".cpp", ".h", ".hpp", ".sh", ".bat", ".ps1",
    ".toml", ".ini", ".env",
}}
_IMAGE_EXTS = {{".png", ".jpg", ".jpeg", ".webp", ".gif", ".svg"}}
_VIDEO_EXTS = {{".mp4"}}
def _kind_for_ext(ext: str) -> str:
    ext = (ext or "").lower()
    if ext in _TEXT_EXTS:
        return "code"
    if ext in _IMAGE_EXTS:
        return "image"
    if ext in _VIDEO_EXTS:
        return "video"
    return "other"
def _guess_mime_for_image_ext(ext: str) -> str:
    e = (ext or "").lower()
    if e in (".jpg", ".jpeg"):
        return "image/jpeg"
    if e == ".webp":
        return "image/webp"
    if e == ".gif":
        return "image/gif"
    if e == ".svg":
        return "image/svg+xml"
    return "image/png"
def _sha256_bytes(b: bytes) -> str:
    h = hashlib.sha256()
    h.update(b)
    return h.hexdigest()
def _split_lines(s: str) -> List[str]:
    return s.replace("\r\n", "\n").replace("\r", "\n").split("\n")
def _chunk_text(file_path: str, text: str, max_lines: int = 250) -> List[Tuple[int, int, str]]:
    lines = _split_lines(text)
    out: List[Tuple[int, int, str]] = []
    n = len(lines)
    i = 0
    while i < n:
        start = i + 1
        end = min(n, i + max_lines)
        chunk = "\n".join(lines[i:end])
        out.append((start, end, chunk))
        i = end
    return out
def _normalize_rel_path(p: str) -> str:
    p = (p or "").replace("\\", "/").strip()
    p = re.sub(r"^/+", "", p)
    if not p or p in (".",):
        raise HTTPException(status_code=400, detail="Invalid path")
    if ":" in p.split("/")[0]:
        raise HTTPException(status_code=400, detail="Invalid path (drive prefix)")
    parts = [x for x in p.split("/") if x not in ("", ".")]
    if any(x == ".." for x in parts):
        raise HTTPException(status_code=400, detail="Invalid path (traversal)")
    return "/".join(parts)
