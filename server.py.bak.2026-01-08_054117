async def _read_upload_limited(f: UploadFile) -> bytes:
    buf = bytearray()
    while True:
        chunk = await f.read(1024 * 1024) # 1MB
        if not chunk:
            break
        buf.extend(chunk)
        if len(buf) > MAX_FILE_BYTES:
            raise HTTPException(status_code=413, detail=f"File too large (> {{MAX_FILE_MB}}MB): {{f.filename}}")
    return bytes(buf)
@app.post("/api/projects/{project_id}/upload")
async def upload_files(
    project_id: str,
    user_key: str = Depends(require_user_key),
    files: List[UploadFile] = File(...),
):
    if not _project_owned(user_key, project_id):
        raise HTTPException(status_code=404, detail="Project not found")
    if not files:
        raise HTTPException(status_code=400, detail="No files uploaded")
    if len(files) > MAX_UPLOAD_FILES:
        raise HTTPException(status_code=400, detail=f"Too many files. Max per request is {{MAX_UPLOAD_FILES}}.")
    saved: List[Dict[str, Any]] = []
    conn = _db()
    try:
        for uf in files:
            filename = (uf.filename or "").strip()
            if not filename:
                continue
            path = _normalize_rel_path(filename)
            ext = Path(filename).suffix.lower()
            kind = _kind_for_ext(ext)
            data = await _read_upload_limited(uf)
            saved_row = _upsert_project_file(
                conn=conn,
                project_id=project_id,
                user_key=user_key,
                path=path,
                filename=Path(path).name,
                kind=kind,
                ext=ext,
                data=data,
            )
            saved.append(saved_row)
        conn.commit()
    finally:
        conn.close()
    _touch_project(project_id, user_key)
    return {{"ok": True, "saved": saved, "max_files_per_request": MAX_UPLOAD_FILES}}
@app.post("/api/projects/{project_id}/upload_zip")
async def upload_zip(
    project_id: str,
    user_key: str = Depends(require_user_key),
    file: UploadFile = File(...),
):
    if not _project_owned(user_key, project_id):
        raise HTTPException(status_code=404, detail="Project not found")
    fname = (file.filename or "").lower()
    if not fname.endswith(".zip"):
        raise HTTPException(status_code=400, detail="file must be a .zip")
    raw = await _read_upload_limited(file) # still respects MAX_FILE_BYTES for the zip itself
    bio = io.BytesIO(raw)
    saved_count = 0
    skipped_count = 0
    total_bytes = 0
    conn = _db()
    try:
        with zipfile.ZipFile(bio) as z:
            infos = [i for i in z.infolist() if not i.is_dir()]
            if len(infos) > MAX_ZIP_FILES:
                raise HTTPException(status_code=400, detail=f"ZIP contains too many files ({{len(infos)}}). Max is {{MAX_ZIP_FILES}}.")
            for info in infos:
                name = info.filename.replace("\\", "/")
                try:
                    rel = _normalize_rel_path(name)
                except HTTPException:
                    skipped_count += 1
                    continue
                if info.file_size > MAX_FILE_BYTES:
                    skipped_count += 1
                    continue
                data = z.read(info)
                total_bytes += len(data)
                if total_bytes > MAX_ZIP_TOTAL_BYTES:
                    raise HTTPException(status_code=400, detail=f"ZIP total extracted size exceeds {{MAX_ZIP_TOTAL_MB}}MB.")
                ext = Path(rel).suffix.lower()
                kind = _kind_for_ext(ext)
                _upsert_project_file(
                    conn=conn,
                    project_id=project_id,
                    user_key=user_key,
                    path=rel,
                    filename=Path(rel).name,
                    kind=kind,
                    ext=ext,
                    data=data,
                )
                saved_count += 1
        conn.commit()
    finally:
        conn.close()
    _touch_project(project_id, user_key)
    return {{"ok": True, "saved_count": saved_count, "skipped_count": skipped_count, "max_zip_files": MAX_ZIP_FILES, "max_zip_total_mb": MAX_ZIP_TOTAL_MB}}
