{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/account/layout,_N_T_/account/upgrade/layout,_N_T_/account/upgrade/page,_N_T_/account/upgrade/"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/account/upgrade/__PAGE__",
    "/account/upgrade",
    "/account",
    "/_index",
    "/_head"
  ]
}